/*
        name : name is the unique name for the sequence 
        sequenceName : its a name which is created in DB , or if you have manually created the sequence in DB, then use the name here 
        initialvalue : seq. no starts from
        allocationSize : cache data , hibernate prefetch this much ides before hand so that it will not query DB again and again 
 */
public class UserDetails {
    @Id
    @GeneratedValue(strategy = GenerationType.SEQUENCE)
    @SequenceGenerator(name= "unique-user-seq", sequenceName = "db-seq-name", initialValue = 100, allocationSize = 10)
    private Long id;
    private String name;
    private String address;
    private String phone;
}
